{
  "name": "taro-app",
  "version": "1.0.0",
  "private": true,
  "description": "Taro React 小程序架子",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch"
  },
  "browserslist": [
    "last 3 Chrome versions",
    "last 3 Firefox versions",
    "last 3 Opera versions",
    "last 3 Edge versions"
  ],
  "dependencies": {
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "^4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/preset-react": "^7.28.5",
    "@tarojs/cli": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "babel-preset-taro": "4.1.11",
    "sass": "^1.62.0",
    "typescript": "^5.0.0"
  }
}
